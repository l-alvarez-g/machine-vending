{
    "name": "enterprise/vending-machine",
    "description": "Enterprise DDD/CQRS Vending Machine using PHP 8.4",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "php-di/php-di": "^7.0",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.1",
        "phpstan/phpstan": "^2.0",
        "symplify/easy-coding-standard": "^12.0",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "App\\Shared\\": "src/Shared/",
            "App\\VendingMachine\\": "src/VendingMachine/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    }
}